{
  "name": "pacman",
  "version": "1.0.0",
  "description": "Pacman-style arcade game with pixel-retro presentation",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dev-server.js",
    "start:test": "node dev-server.js --port 3009",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "vitest": "^3.1.1",
    "jsdom": "^26.0.0",
    "@playwright/test": "^1.52.0"
  }
}
