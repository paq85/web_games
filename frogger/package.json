{
  "name": "frogger",
  "version": "1.0.0",
  "private": true,
  "description": "Frogger - classic arcade traffic and river crossing game",
  "scripts": {
    "serve": "npx http-server -p 3000 -c-1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "vitest": "^3.1.1"
  }
}
